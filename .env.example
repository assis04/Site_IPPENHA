# URL pública do perfil do Instagram (usada para links no frontend)
VITE_INSTAGRAM_PROFILE_URL=https://www.instagram.com/ippenha/

# Alvo do proxy Vite (scripts/wp-dev-proxy-plugin.js). Com o .htaccess actual, *.local não força
# HTTPS — podes usar http://ippenha.local e evitar certificado/TLS no Node.
# VITE_WP_PROXY_TARGET=http://ippenha.local

